<svg width="500" height="500" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="diningWall" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#fff8dc;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#ffefd5;stop-opacity:1" />
    </linearGradient>
  </defs>
  <!-- Walls -->
  <rect width="500" height="500" fill="url(#diningWall)"/>
  <!-- Dining Table -->
  <ellipse cx="250" cy="280" rx="120" ry="90" fill="#D2B48C" stroke="#8B7355" stroke-width="2"/>
  <!-- Table surface -->
  <ellipse cx="250" cy="280" rx="110" ry="80" fill="#DEB887"/>
  <!-- Table leg -->
  <rect x="245" y="370" width="10" height="80" fill="#8B4513" stroke="#654321" stroke-width="1"/>
  <!-- Chairs -->
  <!-- Chair 1 (left) -->
  <rect x="80" y="250" width="60" height="80" fill="#A0522D" stroke="#654321" stroke-width="2"/>
  <rect x="85" y="245" width="50" height="15" fill="#D2B48C" stroke="#8B7355" stroke-width="1"/>
  <!-- Chair 2 (right) -->
  <rect x="360" y="250" width="60" height="80" fill="#A0522D" stroke="#654321" stroke-width="2"/>
  <rect x="365" y="245" width="50" height="15" fill="#D2B48C" stroke="#8B7355" stroke-width="1"/>
  <!-- Chair 3 (top) -->
  <rect x="220" y="120" width="60" height="80" fill="#A0522D" stroke="#654321" stroke-width="2"/>
  <rect x="225" y="115" width="50" height="15" fill="#D2B48C" stroke="#8B7355" stroke-width="1"/>
  <!-- Chandelier -->
  <circle cx="250" cy="60" r="20" fill="#FFD700" stroke="#DAA520" stroke-width="2"/>
  <line x1="250" y1="40" x2="250" y2="20" stroke="#DAA520" stroke-width="2"/>
  <circle cx="240" cy="30" r="3" fill="#FFD700"/>
  <circle cx="260" cy="30" r="3" fill="#FFD700"/>
  <!-- Glass on table -->
  <circle cx="200" cy="260" r="12" fill="#87CEEB" opacity="0.3" stroke="#4A90E2" stroke-width="1"/>
  <circle cx="300" cy="260" r="12" fill="#87CEEB" opacity="0.3" stroke="#4A90E2" stroke-width="1"/>
  <!-- Plates -->
  <circle cx="220" cy="280" r="15" fill="#FFF8DC" stroke="#DAA520" stroke-width="1"/>
  <circle cx="280" cy="280" r="15" fill="#FFF8DC" stroke="#DAA520" stroke-width="1"/>
  <!-- Wall decoration -->
  <rect x="50" y="80" width="100" height="80" fill="#FFE4B5" stroke="#DAA520" stroke-width="2"/>
  <rect x="55" y="85" width="90" height="70" fill="#FFD700" opacity="0.5"/>
  <!-- Window -->
  <rect x="350" y="80" width="100" height="100" fill="#87CEEB" stroke="#4A90E2" stroke-width="2"/>
  <line x1="400" y1="80" x2="400" y2="180" stroke="#4A90E2" stroke-width="1"/>
  <line x1="350" y1="130" x2="450" y2="130" stroke="#4A90E2" stroke-width="1"/>
  <!-- Text -->
  <text x="250" y="480" font-size="20" font-weight="bold" text-anchor="middle" fill="#3d3d3d">Dining Area</text>
</svg>