<svg width="500" height="500" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="sky" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#87CEEB;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#E0F6FF;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="wall" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f5deb3;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#e8d4b5;stop-opacity:1" />
    </linearGradient>
  </defs>
  <!-- Sky -->
  <rect width="500" height="300" fill="url(#sky)"/>
  <!-- Ground -->
  <rect y="300" width="500" height="200" fill="#90EE90"/>
  <!-- House Body -->
  <rect x="100" y="180" width="300" height="180" fill="url(#wall)" stroke="#d4a574" stroke-width="2"/>
  <!-- Roof -->
  <polygon points="100,180 250,80 400,180" fill="#c68d3f" stroke="#b8860b" stroke-width="2"/>
  <!-- Door -->
  <rect x="210" y="280" width="80" height="120" fill="#8B4513" stroke="#654321" stroke-width="2"/>
  <circle cx="280" cy="340" r="4" fill="#FFD700"/>
  <!-- Windows -->
  <rect x="130" y="220" width="50" height="50" fill="#87CEEB" stroke="#4A90E2" stroke-width="2"/>
  <rect x="320" y="220" width="50" height="50" fill="#87CEEB" stroke="#4A90E2" stroke-width="2"/>
  <!-- Window Cross -->
  <line x1="155" y1="220" x2="155" y2="270" stroke="#4A90E2" stroke-width="1"/>
  <line x1="130" y1="245" x2="180" y2="245" stroke="#4A90E2" stroke-width="1"/>
  <line x1="345" y1="220" x2="345" y2="270" stroke="#4A90E2" stroke-width="1"/>
  <line x1="320" y1="245" x2="370" y2="245" stroke="#4A90E2" stroke-width="1"/>
  <!-- Chimney -->
  <rect x="375" y="120" width="25" height="70" fill="#CD5C5C" stroke="#8B3A3A" stroke-width="2"/>
  <!-- Decorative plants -->
  <ellipse cx="90" cy="300" rx="20" ry="30" fill="#228B22"/>
  <ellipse cx="410" cy="300" rx="20" ry="30" fill="#228B22"/>
  <!-- Text -->
  <text x="250" y="470" font-size="20" font-weight="bold" text-anchor="middle" fill="#3d3d3d">Home Exterior</text>
</svg>