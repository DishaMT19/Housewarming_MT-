<svg width="500" height="500" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="kitchenWall" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#fffacd;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#ffefd5;stop-opacity:1" />
    </linearGradient>
  </defs>
  <!-- Walls -->
  <rect width="500" height="500" fill="url(#kitchenWall)"/>
  <!-- Cabinet 1 -->
  <rect x="30" y="80" width="120" height="140" fill="#D2B48C" stroke="#8B7355" stroke-width="2"/>
  <rect x="40" y="90" width="50" height="60" fill="#A0826D" stroke="#654321" stroke-width="1"/>
  <rect x="100" y="90" width="50" height="60" fill="#A0826D" stroke="#654321" stroke-width="1"/>
  <rect x="40" y="160" width="50" height="60" fill="#A0826D" stroke="#654321" stroke-width="1"/>
  <rect x="100" y="160" width="50" height="60" fill="#A0826D" stroke="#654321" stroke-width="1"/>
  <!-- Cabinet 2 -->
  <rect x="170" y="80" width="120" height="140" fill="#D2B48C" stroke="#8B7355" stroke-width="2"/>
  <rect x="180" y="90" width="50" height="60" fill="#A0826D" stroke="#654321" stroke-width="1"/>
  <rect x="240" y="90" width="50" height="60" fill="#A0826D" stroke="#654321" stroke-width="1"/>
  <rect x="180" y="160" width="50" height="60" fill="#A0826D" stroke="#654321" stroke-width="1"/>
  <rect x="240" y="160" width="50" height="60" fill="#A0826D" stroke="#654321" stroke-width="1"/>
  <!-- Counter -->
  <rect x="30" y="250" width="260" height="60" fill="#C0C0C0" stroke="#808080" stroke-width="2"/>
  <!-- Stove -->
  <rect x="310" y="260" width="100" height="80" fill="#C0C0C0" stroke="#696969" stroke-width="2"/>
  <circle cx="325" cy="275" r="8" fill="#808080"/>
  <circle cx="345" cy="275" r="8" fill="#808080"/>
  <circle cx="365" cy="275" r="8" fill="#808080"/>
  <circle cx="385" cy="275" r="8" fill="#808080"/>
  <!-- Sink -->
  <ellipse cx="90" cy="280" rx="25" ry="20" fill="#A9A9A9" stroke="#696969" stroke-width="2"/>
  <ellipse cx="90" cy="280" rx="18" ry="13" fill="#C0C0C0"/>
  <!-- Refrigerator -->
  <rect x="350" y="80" width="110" height="160" fill="#C0C0C0" stroke="#696969" stroke-width="2"/>
  <rect x="360" y="90" width="90" height="70" fill="#87CEEB" opacity="0.5" stroke="#4A90E2" stroke-width="1"/>
  <rect x="360" y="170" width="90" height="60" fill="#87CEEB" opacity="0.5" stroke="#4A90E2" stroke-width="1"/>
  <!-- Microwave -->
  <rect x="200" y="350" width="80" height="60" fill="#D3D3D3" stroke="#696969" stroke-width="2"/>
  <rect x="210" y="360" width="60" height="40" fill="#000" opacity="0.3"/>
  <!-- Text -->
  <text x="250" y="480" font-size="20" font-weight="bold" text-anchor="middle" fill="#3d3d3d">Kitchen</text>
</svg>